{
  "name": "mcp-lanhu",
  "version": "1.0.0",
  "description": "MCP server for Lanhu (蓝湖) design collaboration platform — lets AI assistants read designs, PRDs and slices.",
  "type": "module",
  "license": "MIT",
  "author": "MrDgbot",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrDgbot/lanhu-mcp.git"
  },
  "keywords": ["mcp", "lanhu", "蓝湖", "design", "ai", "cursor", "claude"],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mcp-lanhu": "dist/server.js"
  },
  "files": [
    "dist",
    "config.example.env",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
